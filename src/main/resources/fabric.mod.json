    "client": [
      "me.noramibu.itemeditor.ItemEditorClient"
    ]
  },
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": "*",
    "owo": ">=0.13.0"
  },
  "custom": {
    "itemeditor": {
