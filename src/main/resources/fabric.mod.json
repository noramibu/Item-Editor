{
  "schemaVersion": 1,
  "id": "itemeditor",
  "version": "${version}",
  "name": "Item Editor",
  "description": "Client-side item editor with an extensible workflow for held items.",
  "authors": [
    "noramibu"
  ],
  "contact": {
    "homepage": "https://modrinth.com/project/item-editor",
    "sources": "https://github.com/noramibu/Item-Editor",
    "issues": "https://github.com/noramibu/Item-Editor/issues",
    "discord": "https://discord.gg/FaxbR9eEFW"
  },
  "license": "GPL-3.0-only",
  "icon": "assets/itemeditor/icon.png",
